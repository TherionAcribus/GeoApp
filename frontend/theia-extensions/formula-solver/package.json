{
  "name": "@mysterai/theia-formula-solver",
  "version": "1.0.0",
  "description": "Formula Solver Extension for Mystery Geocaches in Theia IDE",
  "keywords": [
    "theia-extension",
    "formula-solver",
    "geocaching",
    "mysterai",
    "gps-coordinates"
  ],
  "license": "MIT",
  "main": "lib/browser/formula-solver-frontend-module.js",
  "typings": "lib/browser/formula-solver-frontend-module.d.ts",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "scripts": {
    "prepare": "yarn run clean && yarn run build",
    "clean": "rimraf lib",
    "build": "tsc && yarn run copy:assets",
    "copy:assets": "node -e \"require('fs-extra').copySync('src/browser/style', 'lib/browser/style')\"",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "@theia/core": "1.70.2",
    "@theia/filesystem": "1.70.2",
    "@theia/workspace": "1.70.2"
  },
  "peerDependencies": {
    "@theia/core": "1.70.2",
    "theia-ide-zones-ext": "1.70.200"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/formula-solver-frontend-module"
    }
  ]
}
