    "id": "football_formula_checker_realistic",
    "payload": {
      "title": "BR lois et regles du jeu",
      "description": "Ami geocacheur, nous te proposons une serie de caches mysteres sur le theme du football. Pour chacune des questions, les reponses sont a considerer en fonction de la date de sortie de cette cache. 1 A quelle distance du milieu de la ligne de but se situe le point de penalty et a quelle loi correspond cette regle. A = en metres. B = numero de la loi. 2 Quelle est la duree maximale de la pause a la mi temps et a quelle loi correspond cette regle. C = reponse en minutes. D = numero de la loi. 3 Quelle regle concerne la loi 11. E = valeur du mot compose avec A=1 a Z=26. 4 Quelle forme avaient les premiers poteaux de but. F = nombre de lettres de la reponse. 5 Quelle ligne trouve t on au milieu d un terrain. G = valeur du mot avec A=1 a Z=26. 6 Quel mot anglais correspond au coup de pied de coin et a quelle loi correspond cette regle. H = valeur du mot. I = numero de la loi. 7 Le but mesure t il 6,32 m, 7,32 m, 8,32 m ou 9,32 m de large. J = somme des 3 chiffres. 8 Quel mot anglais correspond au coup de pied de reparation et a quelle loi correspond cette regle. K = valeur du mot. L = numero de la loi. N49 12.((A-B)*E-J) E006 00.(C+D+F+G+H+I+K+L-78)",
      "checkers": [
        {
          "name": "Geocaching",
          "url": "https://www.geocaching.com/play/checker.aspx?id=970202"
        }
      ],
      "hint": "Sraqh",
      "max_plugins": 4
    },
    "expected_labels": [
      "formula",
      "coord_transform",
      "checker_available"
    ],
    "expected_workflow": "formula",
    "expected_plan_steps": [
      "detect-formulas",
      "extract-questions",
      "search-answers",
      "calculate-final-coordinates",
      "validate-with-checker"
    ]
