{
  "name": "atbash",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Plugin pour encoder/décoder le chiffrement Atbash (A↔Z, B↔Y, etc.).",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "categories": [
    "AlphabetsDecryption",
    "ClassicCiphers"
  ],
  "dependencies": [],
  "kinds": [
    "code"
  ],
  "brute_force": false,
  "enable_scoring": true,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte en clair ou chiffré Atbash...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": [
        "decode",
        "encode",
        "detect"
      ],
      "default": "decode",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Mode de traitement",
      "options": [
        "strict",
        "smooth"
      ],
      "default": "smooth"
    },
    "embedded": {
      "type": "boolean",
      "label": "Texte chiffré intégré",
      "default": false
    },
    "allowed_chars": {
      "type": "string",
      "label": "Caractères de séparation autorisés",
      "placeholder": "Exemple: espace, ponctuation...",
      "default": " \t\r\n.:;,_-'\"!?"
    },
    "enable_scoring": {
      "type": "boolean",
      "label": "Scoring (legacy)",
      "default": true,
      "hidden": true
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  },
  "text_handling": {
    "fields": [
      "text"
    ],
    "allowed_ranges": [
      "0041-005A"
    ],
    "allowed_characters": " \t\r\n.:;,_-'\"!?",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "upper",
      "map_characters": {}
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "letters",
    "tags": ["frequent", "classic", "substitution", "no_key"],
    "priority": 80,
    "family": "substitution",
    "preferred_when": ["letters_only", "short_input"]
  }
}
