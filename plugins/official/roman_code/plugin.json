{
  "name": "roman_code",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Convertit un entier décimal en chiffres romains et inversement.",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": ["AlphabetsDecryption"],
  "kinds": ["code"],
  "brute_force": false,
  "enable_scoring": true,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": false,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": false,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Valeur à convertir",
      "placeholder": "Entrez un nombre ou des chiffres romains...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": ["decode", "encode"],
      "default": "decode",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Validation",
      "options": ["smooth", "strict"],
      "default": "smooth"
    },
    "allowed_chars": {
      "type": "string",
      "label": "Caractères autorisés",
      "placeholder": "Laissez vide pour les caractères par défaut"
    },
    "embedded": {
      "type": "boolean",
      "label": "Code intégré",
      "default": false
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "letters",
    "tags": ["frequent", "numeral", "no_key"],
    "priority": 70,
    "family": "numeral",
    "preferred_when": ["roman_like", "letters_only", "short_input"]
  }
}
