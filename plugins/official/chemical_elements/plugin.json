{
  "name": "chemical_elements",
  "version": "1.1.0",
  "plugin_api_version": "2.0",
  "description": "Convertit les symboles chimiques en numéros atomiques et vice-versa.",
  "author": "MysteryAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": [
    "Chemistry",
    "AlphabetsDecryption"
  ],
  "kinds": [
    "code"
  ],
  "brute_force": false,
  "enable_scoring": false,
  "accept_accents": true,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez du texte avec des symboles chimiques ou des numéros atomiques...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": [
        "decode",
        "encode",
        "detect"
      ],
      "default": "decode",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Mode de décodage",
      "options": [
        "strict",
        "smooth"
      ],
      "default": "smooth"
    },
    "embedded": {
      "type": "boolean",
      "label": "Symboles intégrés dans le texte",
      "default": true
    },
    "allowed_chars": {
      "type": "string",
      "label": "Caractères autorisés",
      "placeholder": "Exemple: ° . , ; : -",
      "default": " \t\r\n.:;,_-°"
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  },
  "text_handling": {
    "fields": [
      "text"
    ],
    "allowed_ranges": [
      "0030-0039",
      "0041-005A",
      "0061-007A"
    ],
    "allowed_characters": " \t\r\n.:;,_-°",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "preserve",
      "map_characters": {}
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "words",
    "tags": ["substitution", "no_key"],
    "priority": 55,
    "family": "element_code",
    "preferred_when": ["chemical_like", "words_only", "grouped_input"],
    "supports_grouped_input": true
  }
}
