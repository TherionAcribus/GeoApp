{
  "name": "prime_numbers",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Plugin pour encoder/décoder avec le code des nombres premiers (A=2, B=3, ...).",
  "author": "MysteryAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": ["SymbolsDecryption"],
  "kinds": ["code"],
  "brute_force": true,
  "enable_scoring": true,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true,
    "detect": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte ou la séquence de nombres premiers...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": ["decode", "encode", "detect"],
      "default": "decode",
      "required": true
    },
    "separator": {
      "type": "select",
      "label": "Séparateur",
      "options": ["auto", "comma", "space", "semicolon", "newline", "tab", "none", "custom"],
      "default": "auto"
    },
    "separator_custom": {
      "type": "string",
      "label": "Séparateur personnalisé",
      "placeholder": "Ex: |",
      "default": ""
    },
    "bruteforce": {
      "type": "boolean",
      "label": "Bruteforce",
      "default": false
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  },
  "text_handling": {
    "fields": ["text"],
    "allowed_ranges": ["0041-005A"],
    "allowed_characters": " ,;\t\r\n",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "upper",
      "map_characters": {}
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "digits",
    "tags": ["numeral", "no_key"],
    "priority": 60,
    "family": "numeral",
    "preferred_when": ["prime_like", "digits_only", "grouped_input", "digit_groups"],
    "supports_grouped_input": true
  }
}
