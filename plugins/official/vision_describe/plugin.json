{
  "name": "vision_describe",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Description visuelle IA via endpoint OpenAI-compatible (LMStudio ou OpenRouter). Identifie le contenu d'une image: contes, scenes, personnages, animaux.",
  "author": "GeoApp",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": ["requests"],
  "categories": ["Analysis", "Image", "AI"],
  "kinds": ["image", "analyze"],
  "brute_force": false,
  "heavy_cpu": false,
  "needs_network": true,
  "needs_filesystem": false,
  "timeout_seconds": 90,
  "input_types": {
    "geocache_id": {
      "type": "string",
      "label": "ID de la geocache",
      "required": false,
      "default_value_source": "geocache_id"
    },
    "context": {
      "type": "string",
      "label": "Contexte optionnel",
      "required": false,
      "placeholder": "ex: contes pour enfants, symboles templiers"
    },
    "provider": {
      "type": "select",
      "label": "Fournisseur vision",
      "required": false,
      "options": [
        {"value": "lmstudio", "label": "LMStudio"},
        {"value": "openrouter", "label": "OpenRouter"}
      ],
      "default": "lmstudio"
    },
    "base_url": {
      "type": "string",
      "label": "Base URL OpenAI-compatible",
      "required": false,
      "placeholder": "http://localhost:1234 ou https://openrouter.ai/api/v1"
    },
    "model": {
      "type": "string",
      "label": "Modele vision",
      "required": false,
      "placeholder": "ex: llava, qwen2-vl, openai/gpt-4o-mini"
    }
  },
  "output_types": {
    "descriptions": {"type": "array", "label": "Descriptions visuelles"},
    "images_analyzed": {"type": "integer", "label": "Nombre d'images analysees"}
  },
  "metasolver": {
    "eligible": false
  }
}
