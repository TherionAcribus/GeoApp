{
  "name": "polybius_square",
  "version": "1.0.1",
  "plugin_api_version": "2.0",
  "description": "Plugin de chiffrement et déchiffrement utilisant le carré de Polybe.",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": ["AlphabetsDecryption"],
  "kinds": ["code"],
  "brute_force": true,
  "enable_scoring": true,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte ici...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": ["decode", "encode"],
      "default": "decode",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Mode strict",
      "options": ["strict", "smooth"],
      "default": "smooth"
    },
    "key": {
      "type": "string",
      "label": "Mot-clé (optionnel)",
      "placeholder": "Mot-clé pour mélanger l'alphabet",
      "default": ""
    },
    "grid_size": {
      "type": "select",
      "label": "Taille de la grille",
      "options": ["5x5", "6x6"],
      "default": "5x5"
    },
    "alphabet_mode": {
      "type": "select",
      "label": "Mode alphabet",
      "options": ["I=J", "C=K", "W=VV"],
      "default": "I=J"
    },
    "output_format": {
      "type": "select",
      "label": "Format de sortie",
      "options": ["numbers", "coordinates", "dots"],
      "default": "numbers"
    },
    "embedded": {
      "type": "boolean",
      "label": "Code intégré dans le texte",
      "default": false
    },
    "allowed_chars": {
      "type": "string",
      "label": "Caractères autorisés (séparateurs)",
      "placeholder": "Exemple: ,.;:-",
      "default": " ,.;:!?-_"
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "digits",
    "tags": ["frequent", "substitution", "no_key"],
    "priority": 65,
    "family": "grid_code",
    "preferred_when": ["polybius_like", "digits_only", "grouped_input"],
    "supports_grouped_input": true
  }
}
