{
  "name": "abaddon_code",
  "version": "1.7.0",
  "plugin_api_version": "2.0",
  "description": "Plugin de chiffrement et déchiffrement utilisant le code Abaddon (3 symboles: þ, µ, ¥).",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "categories": [
    "SymbolsDecryption"
  ],
  "dependencies": [],
  "brute_force": false,
  "enable_scoring": true,
  "accept_accents": false,
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte ici...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": [
        "decode",
        "encode",
        "detect"
      ],
      "default": "decode",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Mode strict",
      "options": [
        "strict",
        "smooth"
      ],
      "default": "smooth"
    },
    "embedded": {
      "type": "boolean",
      "label": "Code Abaddon intégré dans un texte",
      "default": false
    },
    "allowed_chars": {
      "type": "string",
      "label": "Caractères autorisés (optionnel)",
      "placeholder": "Ex: .:;,_-°",
      "default": " \t\r\n.:;,_-°"
    },
    "enable_scoring": {
      "type": "boolean",
      "label": "Scoring (legacy)",
      "default": true,
      "hidden": true
    }
  },
  "output_types": {
    "encoded_text": {
      "type": "string",
      "label": "Texte chiffré"
    },
    "decoded_text": {
      "type": "string",
      "label": "Texte déchiffré"
    }
  },
  "text_handling": {
    "fields": [
      "text"
    ],
    "allowed_ranges": [
      "0041-005A"
    ],
    "allowed_characters": " \t\r\n",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "upper",
      "map_characters": {
        "μ": "µ"
      }
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "symbols",
    "tags": ["substitution", "no_key"],
    "priority": 60
  }
}
