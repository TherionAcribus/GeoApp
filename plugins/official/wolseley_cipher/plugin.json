{
  "name": "wolseley_cipher",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Chiffre de Wolseley (substitution réversible à partir d'une clé).",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": ["AlphabetsDecryption"],
  "kinds": ["code"],
  "brute_force": true,
  "enable_scoring": true,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": false,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": false,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte à chiffrer ou déchiffrer...",
      "required": true
    },
    "key": {
      "type": "string",
      "label": "Clé (mot)",
      "placeholder": "SECRET",
      "default": ""
    },
    "removed_letter": {
      "type": "select",
      "label": "Lettre supprimée (J=I, V=U, W=V)",
      "options": ["J", "V", "W", "none"],
      "default": "J"
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": ["encode", "decode", "detect", "bruteforce"],
      "default": "decode",
      "required": true
    },
    "candidate_keys": {
      "type": "string",
      "label": "Clés candidates (bruteforce/detect)",
      "placeholder": "Ex: SECRET,ALPHABET,WOLSELEY"
    },
    "max_results": {
      "type": "number",
      "label": "Nombre max de résultats (bruteforce)",
      "min": 1,
      "max": 50,
      "default": 10
    },
    "bruteforce": {
      "type": "boolean",
      "label": "Forcer le mode bruteforce",
      "default": false
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Texte transformé"
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "letters",
    "tags": ["substitution"],
    "priority": 45
  }
}
