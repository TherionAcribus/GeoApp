{
  "name": "vision_ocr",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "OCR IA (vision) via endpoint OpenAI-compatible (LMStudio ou OpenRouter) sur images de geocache",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": ["requests"],
  "categories": ["Analysis", "Image", "AI"],
  "kinds": ["image", "analyze"],
  "brute_force": false,
  "heavy_cpu": false,
  "needs_network": true,
  "needs_filesystem": false,
  "timeout_seconds": 90,
  "input_types": {
    "geocache_id": {
      "type": "string",
      "label": "ID de la geocache",
      "required": true,
      "default_value_source": "geocache_id"
    },
    "provider": {
      "type": "select",
      "label": "Fournisseur vision",
      "required": false,
      "options": [
        {"value": "lmstudio", "label": "LMStudio"},
        {"value": "openrouter", "label": "OpenRouter"}
      ],
      "default": "lmstudio"
    },
    "base_url": {
      "type": "string",
      "label": "Base URL OpenAI-compatible",
      "required": false,
      "placeholder": "http://localhost:1234 ou https://openrouter.ai/api/v1"
    },
    "model": {
      "type": "string",
      "label": "Modele vision",
      "required": false,
      "placeholder": "ex: llava, qwen2-vl, openai/gpt-4o-mini"
    },
    "language": {
      "type": "select",
      "label": "Langue (indicative)",
      "required": false,
      "options": [
        {"value": "auto", "label": "Auto"},
        {"value": "fr", "label": "Francais"},
        {"value": "en", "label": "Anglais"}
      ],
      "default": "auto"
    }
  },
  "output_types": {
    "ocr_text": {"type": "string", "label": "Texte OCR"},
    "images_analyzed": {"type": "integer", "label": "Nombre d'images analysees"}
  }
}
