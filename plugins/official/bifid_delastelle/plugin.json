{
  "name": "bifid_delastelle",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Plugin de chiffrement et déchiffrement utilisant le chiffre bifide de Delastelle.",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": [
    "AlphabetsDecryption"
  ],
  "kinds": [
    "code"
  ],
  "brute_force": true,
  "enable_scoring": true,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte ici...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": [
        "decode",
        "encode"
      ],
      "default": "decode",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Mode strict",
      "options": [
        "strict",
        "smooth"
      ],
      "default": "smooth"
    },
    "key": {
      "type": "string",
      "label": "Mot-clé (optionnel)",
      "placeholder": "Mot-clé pour créer la grille de Polybe",
      "default": ""
    },
    "grid_size": {
      "type": "select",
      "label": "Taille de la grille",
      "options": [
        "5x5",
        "6x6"
      ],
      "default": "5x5"
    },
    "alphabet_mode": {
      "type": "select",
      "label": "Mode alphabet",
      "options": [
        "I=J",
        "C=K",
        "W=VV"
      ],
      "default": "I=J"
    },
    "period": {
      "type": "number",
      "label": "Période (taille des blocs)",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 5
    },
    "coordinate_order": {
      "type": "select",
      "label": "Ordre des coordonnées",
      "options": [
        "ligne-colonne",
        "colonne-ligne"
      ],
      "default": "ligne-colonne"
    },
    "enable_scoring": {
      "type": "boolean",
      "label": "Scoring (legacy)",
      "default": true,
      "hidden": true
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Texte transformé"
    }
  },
  "text_handling": {
    "fields": [
      "text",
      "key"
    ],
    "allowed_ranges": [
      "0030-0039",
      "0041-005A"
    ],
    "allowed_characters": " \t\r\n",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "upper",
      "map_characters": {}
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "letters",
    "tags": ["substitution"],
    "priority": 45
  }
}
