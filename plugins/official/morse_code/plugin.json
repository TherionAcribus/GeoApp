{
  "name": "morse_code",
  "version": "1.2.0",
  "plugin_api_version": "2.0",
  "description": "Plugin pour chiffrer et déchiffrer le code Morse (A-Z, 0-9).",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": [
    "SymbolsDecryption"
  ],
  "kinds": [
    "code"
  ],
  "brute_force": false,
  "enable_scoring": true,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte en clair ou en Morse...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": [
        "decode",
        "encode",
        "detect"
      ],
      "default": "decode",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Mode strict",
      "options": [
        "strict",
        "smooth"
      ],
      "default": "smooth"
    },
    "embedded": {
      "type": "boolean",
      "label": "Code Morse intégré dans un texte",
      "default": false
    },
    "allowed_chars": {
      "type": "string",
      "label": "Séparateurs autorisés (optionnel)",
      "placeholder": "Ex:  /",
      "default": " \t\r\n/"
    },
    "enable_scoring": {
      "type": "boolean",
      "label": "Scoring (legacy)",
      "default": true,
      "hidden": true
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Texte transformé"
    }
  },
  "text_handling": {
    "fields": [
      "text"
    ],
    "allowed_ranges": [
      "0030-0039",
      "0041-005A"
    ],
    "allowed_characters": " \t\r\n./-",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "upper",
      "map_characters": {}
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "symbols",
    "tags": ["frequent", "classic", "substitution", "no_key"],
    "priority": 85,
    "family": "symbol_code",
    "preferred_when": ["morse_like", "symbols_only", "grouped_input"],
    "supports_grouped_input": true
  }
}
