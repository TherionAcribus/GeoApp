{
  "name": "written_coords_converter",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Reconnaissance de coordonnées GPS écrites en toutes lettres (orchestrateur multi-langues)",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": ["Coordinates"],
  "kinds": ["analyze"],
  "brute_force": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "input_types": {
    "text": {
      "type": "textarea",
      "label": "Texte à analyser",
      "required": true
    },
    "languages": {
      "type": "select",
      "label": "Langue",
      "options": [
        "auto",
        "fr",
        "en",
        "fr,en"
      ],
      "default": "auto"
    },
    "max_candidates": {
      "type": "number",
      "label": "Max candidats",
      "default": 20,
      "min": 1,
      "max": 200
    },
    "include_deconcat": {
      "type": "checkbox",
      "label": "Activer la détection concaténée",
      "default": true
    },
    "origin_coords": {
      "type": "string",
      "label": "Coordonnées d'origine (optionnel)",
      "required": false
    }
  },
  "output_types": {
    "results": {
      "type": "object",
      "label": "Coordonnées candidates"
    }
  }
}
