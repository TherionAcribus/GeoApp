{
  "name": "gold_bug",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Plugin pour encoder/décoder avec le chiffre du Scarabée d'or (Gold-Bug cipher).",
  "author": "MysteryAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": [
    "SymbolsDecryption"
  ],
  "kinds": [
    "code"
  ],
  "brute_force": false,
  "enable_scoring": false,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte ou la séquence de symboles du Scarabée d'or...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": [
        "decode",
        "encode",
        "detect"
      ],
      "default": "decode",
      "required": true
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  },
  "text_handling": {
    "fields": [
      "text"
    ],
    "allowed_ranges": [
      "0041-005A"
    ],
    "allowed_characters": " \t\r\n.:;,_-'\"!?",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "upper",
      "map_characters": {}
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "symbols",
    "tags": ["substitution", "no_key"],
    "priority": 55,
    "family": "symbol_code",
    "preferred_when": ["gold_bug_like", "mixed_input", "symbols_only"]
  }
}
