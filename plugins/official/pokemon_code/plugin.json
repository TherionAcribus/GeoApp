{
  "name": "pokemon_code",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Plugin de chiffrement et déchiffrement du code Pokémon. Chaque lettre est représentée par une syllabe issue des cris/sons des Pokémon (ex: A=PI, B=MON, C=FLA, etc.).",
  "author": "MysterAI Team",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": ["Substitution", "Pokemon"],
  "kinds": ["code"],
  "brute_force": false,
  "enable_scoring": true,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "textarea",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte à chiffrer ou déchiffrer (ex: PIMONFLALU pour 'ABCD')..."
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": ["encode", "decode", "detect"],
      "default": "decode"
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Texte transformé"
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "letters",
    "tags": ["substitution", "no_key"],
    "priority": 40,
    "family": "substitution",
    "preferred_when": ["letters_only"]
  }
}
