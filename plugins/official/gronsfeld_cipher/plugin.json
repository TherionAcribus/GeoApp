{
  "name": "gronsfeld_cipher",
  "version": "1.0.0",
  "plugin_api_version": "2.0",
  "description": "Chiffre de Gronsfeld (variante de Vigenère avec clé numérique).",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": [
    "AlphabetsDecryption"
  ],
  "kinds": [
    "code"
  ],
  "brute_force": false,
  "enable_scoring": false,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte ici...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": [
        "decode",
        "encode"
      ],
      "default": "decode",
      "required": true
    },
    "key": {
      "type": "string",
      "label": "Clé numérique (0-9)",
      "placeholder": "Entrez la clé (ex: 1234)",
      "default": "",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Mode strict",
      "options": [
        "strict",
        "smooth"
      ],
      "default": "smooth"
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  },
  "text_handling": {
    "fields": [
      "text",
      "key"
    ],
    "allowed_ranges": [
      "0030-0039",
      "0041-005A",
      "0061-007A"
    ],
    "allowed_characters": " \t\r\n.:;,_-'\"!?",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "upper",
      "map_characters": {}
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "letters",
    "tags": ["classic", "substitution"],
    "priority": 50,
    "family": "substitution",
    "preferred_when": ["letters_only", "long_input"],
    "requires_key": true
  }
}
