{
  "name": "letter_value",
  "version": "1.2.0",
  "plugin_api_version": "2.0",
  "description": "Convertit les lettres en valeurs numériques selon leur position dans l'alphabet (A=1, B=2, etc.).",
  "author": "MysteryAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": [
    "AlphabetsDecryption"
  ],
  "kinds": [
    "code"
  ],
  "brute_force": true,
  "enable_scoring": false,
  "accept_accents": false,
  "heavy_cpu": false,
  "needs_network": false,
  "needs_filesystem": false,
  "timeout_seconds": 30,
  "capabilities": {
    "analyze": true,
    "decode": true,
    "encode": true
  },
  "defaults": {
    "include_in_analysis": true,
    "include_in_decode": true
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte contenant des lettres à convertir...",
      "required": true
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": [
        "decode",
        "encode",
        "detect"
      ],
      "default": "decode",
      "required": true
    },
    "strict": {
      "type": "select",
      "label": "Mode de détection",
      "options": [
        "strict",
        "smooth"
      ],
      "default": "smooth"
    },
    "embedded": {
      "type": "boolean",
      "label": "Texte intégré",
      "default": true
    },
    "allowed_chars": {
      "type": "string",
      "label": "Caractères autorisés",
      "placeholder": "Espace, ponctuation, etc.",
      "default": " ,.°"
    },
    "format": {
      "type": "select",
      "label": "Format de sortie",
      "options": [
        "standard",
        "decimal",
        "combined"
      ],
      "default": "combined"
    },
    "checksum": {
      "type": "boolean",
      "label": "Utiliser le checksum",
      "default": false
    },
    "bruteforce": {
      "type": "boolean",
      "label": "Bruteforce (decode : standard + checksum)",
      "default": false
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  },
  "text_handling": {
    "fields": [
      "text"
    ],
    "allowed_ranges": [
      "0030-0039",
      "0041-005A",
      "0061-007A"
    ],
    "allowed_characters": " \t\r\n.,°:;,_-'\"!?",
    "unknown_char_policy": "warn_keep",
    "normalize": {
      "remove_diacritics": true,
      "case": "upper",
      "map_characters": {}
    }
  },
  "metasolver": {
    "eligible": true,
    "input_charset": "mixed",
    "tags": ["frequent", "numeral", "no_key"],
    "priority": 85
  }
}
