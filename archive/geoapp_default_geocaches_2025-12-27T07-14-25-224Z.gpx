        <groundspeak:attribute id="4" inc="1">1 km–10 km hike</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>2.0</groundspeak:difficulty>
      <groundspeak:terrain>2.0</groundspeak:terrain>
      <groundspeak:short_description html="True" />
      <groundspeak:long_description html="True">&lt;span id="ctl00_ContentBody_LongDescription"&gt;&lt;p style="text-align:center;"&gt;Boucle de Villeneuve-le-Comte&lt;/p&gt;
&lt;p style="text-align:center;"&gt;Le paysage de Villeneuve-le-Comte s’est, depuis des siècles, construit autour de paysages agricoles dans un environnement forestier.&lt;/p&gt;
&lt;p style="text-align:center;"&gt;Dans un rayon de 2 km autour du centre du village, des chemins de randonnées nous permettent de découvrir la diversité et la richesse de ces paysages préservés jusqu'à aujourd'hui.&lt;/p&gt;
&lt;p style="text-align:center;"&gt;Ce parcours s'adresse bien évidemment aux habitants de la commune qui pourront boucler le circuit en 3 heures, mais aussi emprunter des variantes qui réduiront les parcours.&lt;/p&gt;&lt;/span&gt;</groundspeak:long_description>
      <groundspeak:encoded_hints />
    </groundspeak:cache>
  </wpt>
