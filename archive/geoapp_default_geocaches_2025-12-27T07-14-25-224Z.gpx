      <groundspeak:difficulty>1.5</groundspeak:difficulty>
      <groundspeak:terrain>2.0</groundspeak:terrain>
      <groundspeak:short_description html="True" />
      <groundspeak:long_description html="True">&lt;span id="ctl00_ContentBody_LongDescription"&gt;&lt;p&gt;&lt;strong&gt;A. Quel est le poids d'un éléphant adulte environ ?&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;5 kg      = 0&lt;/p&gt;
&lt;p&gt;50 kg     = 1&lt;/p&gt;
&lt;p&gt;500 kg   = 2&lt;/p&gt;
&lt;p&gt;5000 kg = 3&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;B. Où vivent en général les chameaux ?&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;Dans l'océan      = 2&lt;/p&gt;
&lt;p&gt;A la montagne   = 3&lt;/p&gt;
&lt;p&gt;Dans le désert   = 4&lt;/p&gt;
&lt;p&gt;Dans le ciel        = 5&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;C. Quel animal court le plus vite ?&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;Le guépard    = 1&lt;/p&gt;
&lt;p&gt;Le zèbre        = 2&lt;/p&gt;
&lt;p&gt;Le chien        = 3&lt;/p&gt;
&lt;p&gt;La tortue       = 4&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;D. Combien de pattes ont les araignées ?&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;5   = 4&lt;/p&gt;
&lt;p&gt;6   = 5&lt;/p&gt;
&lt;p&gt;7   = 6&lt;/p&gt;
&lt;p&gt;8   = 7&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;E. Quel animal est le plus grand au monde ?&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;La girafe      = 4&lt;/p&gt;
&lt;p&gt;Le requin     = 5     &lt;/p&gt;
&lt;p&gt;La baleine   = 6&lt;/p&gt;
&lt;p&gt;L'ours          = 7&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;F. Que mangent les lions ?&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;Du poisson      = 3&lt;/p&gt;
&lt;p&gt;De l'herbe        = 4&lt;/p&gt;
&lt;p&gt;De la viande    = 5&lt;/p&gt;
&lt;p&gt;Des fruits         = 6&lt;/p&gt;
&lt;p style="text-align:center;"&gt;&lt;span style="font-size:20px;"&gt;&lt;strong&gt;N 48° 49. ABC   E 002° 51. DEF&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style="text-align:center;"&gt;&lt;span style="font-size:20px;"&gt;&lt;strong&gt;Passez votre résultat dans le checker  pour avoir les coordonnées finales !&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/span&gt;</groundspeak:long_description>
      <groundspeak:encoded_hints>Nh perhk</groundspeak:encoded_hints>
    </groundspeak:cache>
  </wpt>
