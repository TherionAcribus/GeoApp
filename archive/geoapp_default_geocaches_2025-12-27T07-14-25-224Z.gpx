      <groundspeak:attributes>
        <groundspeak:attribute id="1" inc="1">Recommended for kids</groundspeak:attribute>
        <groundspeak:attribute id="2" inc="1">Stroller accessible</groundspeak:attribute>
        <groundspeak:attribute id="3" inc="1">Dogs allowed</groundspeak:attribute>
        <groundspeak:attribute id="4" inc="1">&lt;1 km hike</groundspeak:attribute>
        <groundspeak:attribute id="5" inc="1">Geocaching.com solution checker enabled</groundspeak:attribute>
