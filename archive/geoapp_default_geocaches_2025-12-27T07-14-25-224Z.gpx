      <groundspeak:long_description html="True">&lt;span id="ctl00_ContentBody_LongDescription"&gt;&lt;p style="text-align:center;"&gt;&lt;span style="font-size:26px;"&gt;VLC 6&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;Quel était le nom de villeneuve le comte en 1260 ?&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;En quelle année l'église a été classée monument historique ?&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;Quel était le nom du maire en 1881 ?&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;Quelle personnalité à vécu à Villeneuve le comte ?&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;Combien y avait-il d'habitants en 1931 ?&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;Quel animal est représenté sur l'armoirie de la ville ?&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;(source wikipedia)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt; &lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:22px;"&gt;NOTER LES REPONSES DANS CERTITUDE SANS ESPACE SANS ACCENT&lt;/span&gt;&lt;/p&gt;
&lt;p&gt; &lt;/p&gt;
&lt;div style="text-align:center;"&gt;&lt;a href="https://www.certitudes.org/certitude?wp=GCBEKF0"&gt;&lt;img src="https://www.certitudes.org/logo?wp=GCBEKF0"/&gt;&lt;/a&gt;
