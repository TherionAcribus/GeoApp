    <groundspeak:cache id="10" archived="False" available="True">
      <groundspeak:name>Boucle de Villeneuve-le-Comte</groundspeak:name>
      <groundspeak:placed_by>powerdancejm &amp; flo</groundspeak:placed_by>
      <groundspeak:owner id="0">powerdancejm &amp; flo</groundspeak:owner>
      <groundspeak:type>Traditional Cache</groundspeak:type>
      <groundspeak:container>micro</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="1" inc="1">Recommended for kids</groundspeak:attribute>
        <groundspeak:attribute id="2" inc="1">Dogs allowed</groundspeak:attribute>
        <groundspeak:attribute id="3" inc="1">Bicycles allowed</groundspeak:attribute>
        <groundspeak:attribute id="4" inc="1">1 km–10 km hike</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>2.0</groundspeak:difficulty>
      <groundspeak:terrain>1.5</groundspeak:terrain>
      <groundspeak:short_description html="True" />
      <groundspeak:long_description html="True">&lt;span id="ctl00_ContentBody_LongDescription"&gt;&lt;p style="text-align:center;"&gt;Boucle de Villeneuve-le-Comte&lt;/p&gt;
&lt;p style="text-align:center;"&gt;Le paysage de Villeneuve-le-Comte s’est, depuis des siècles, construit autour de paysages agricoles dans un environnement forestier.&lt;/p&gt;
&lt;p style="text-align:center;"&gt;Dans un rayon de 2 km autour du centre du village, des chemins de randonnées nous permettent de découvrir la diversité et la richesse de ces paysages préservés jusqu'à aujourd'hui.&lt;/p&gt;
&lt;p style="text-align:center;"&gt;Ce parcours s'adresse bien évidemment aux habitants de la commune qui pourront boucler le circuit en 3 heures, mais aussi emprunter des variantes qui réduiront les parcours.&lt;/p&gt;&lt;/span&gt;</groundspeak:long_description>
      <groundspeak:encoded_hints>Qrffhf</groundspeak:encoded_hints>
    </groundspeak:cache>
  </wpt>
  <wpt lat="48.81633333333333" lon="2.8472333333333335">
    <time>2025-10-28T00:00:00Z</time>
    <name>GCBEKKG</name>
    <desc>VLC 11 by powerdancejm &amp; flo, Unknown (Mystery) Cache (2.0/2.0)</desc>
    <url>https://coord.info/GCBEKKG</url>
    <urlname>VLC 11</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Unknown (Mystery) Cache</type>
    <groundspeak:cache id="11" archived="False" available="True">
      <groundspeak:name>VLC 11</groundspeak:name>
      <groundspeak:placed_by>powerdancejm &amp; flo</groundspeak:placed_by>
      <groundspeak:owner id="0">powerdancejm &amp; flo</groundspeak:owner>
      <groundspeak:type>Unknown (Mystery) Cache</groundspeak:type>
      <groundspeak:container>small</groundspeak:container>
      <groundspeak:attributes>
