{
    "name": "bifid_delastelle",
    "version": "1.0.0",
    "description": "Plugin de chiffrement et déchiffrement utilisant le chiffre bifide de Delastelle",
    "author": "MysterAI",
    "plugin_type": "python",
    "entry_point": "main.py",
    "dependencies": [],
    "categories": ["AlphabetsDecryption"],
    "brute_force": true,
    "enable_scoring": true,
    "accept_accents": false,
    "scoring_method": {
        "type": "lexical",
        "custom_weights": {
            "lexical": 0.8,
            "gps": 0.2
        }
    },
    "input_types": {
        "text": {
            "type": "string",
            "label": "Texte à traiter",
            "placeholder": "Entrez le texte ici..."
        },
        "mode": {
            "type": "select",
            "label": "Mode",
            "options": ["decode", "encode"],
            "default": "decode"
        },
        "strict": {
            "type": "select",
            "label": "Mode strict",
            "options": ["strict", "smooth"],
            "default": "smooth"
        },
        "key": {
            "type": "string",
            "label": "Mot-clé (optionnel)",
            "placeholder": "Mot-clé pour créer la grille de Polybe",
            "default": ""
        },
        "grid_size": {
            "type": "select",
            "label": "Taille de la grille",
            "options": ["5x5", "6x6"],
            "default": "5x5"
        },
        "alphabet_mode": {
            "type": "select",
            "label": "Mode alphabet",
            "options": ["I=J", "C=K", "W=VV"],
            "default": "I=J",
            "condition": "grid_size == '5x5'"
        },
        "period": {
            "type": "number",
            "label": "Période (taille des blocs)",
            "min": 1,
            "max": 50,
            "step": 1,
            "default": 5
        },
        "coordinate_order": {
            "type": "select",
            "label": "Ordre des coordonnées",
            "options": ["ligne-colonne", "colonne-ligne"],
            "default": "ligne-colonne"
        }
    },
    "output_types": {
        "encoded_text": {
            "type": "string",
            "label": "Texte chiffré"
        },
        "decoded_text": {
            "type": "string",
            "label": "Texte déchiffré"
        }
    }
} 