{
  "name": "consonants_vowels_rank",
  "version": "1.0.0",
  "description": "Plugin de chiffrement et décodage via le chiffre par rang Consonnes/Voyelles (C1, V1, etc.)",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": ["AlphabetsDecryption"],
  "brute_force": true,
  "enable_scoring": true,
  "accept_accents": false,
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Saisissez le texte à encoder ou décoder..."
    },
    "variant": {
      "type": "select",
      "label": "Variante du chiffre",
      "options": [
        {"value": "both", "label": "Consonnes + Voyelles (C1, V1, ...)"},
        {"value": "consonants", "label": "Consonnes seulement"},
        {"value": "vowels", "label": "Voyelles seulement"}
      ],
      "default": "both"
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": ["encode", "decode"],
      "default": "decode"
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Résultat"
    }
  }
} 