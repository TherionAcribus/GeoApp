{
  "name": "ubchi_cipher",
  "version": "1.0.0",
  "description": "Plugin de chiffrement et déchiffrement utilisant le chiffre Ubchi (double transposition)",
  "author": "MysterAI",
  "plugin_type": "python",
  "entry_point": "main.py",
  "dependencies": [],
  "categories": ["Transposition"],
  "brute_force": true,
  "enable_scoring": true,
  "accept_accents": false,
  "scoring_method": {
    "type": "lexical",
    "custom_weights": {
      "lexical": 0.8,
      "gps": 0.2
    }
  },
  "input_types": {
    "text": {
      "type": "string",
      "label": "Texte à traiter",
      "placeholder": "Entrez le texte à chiffrer ou déchiffrer..."
    },
    "keyword": {
      "type": "string",
      "label": "Mot-clé",
      "placeholder": "Clé de transposition (ex: UBER)",
      "default": "UBER"
    },
    "null_letters": {
      "type": "number",
      "label": "Nombre de lettres nulles (encodage)",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 1
    },
    "mode": {
      "type": "select",
      "label": "Mode",
      "options": ["encode", "decode", "bruteforce"],
      "default": "decode"
    }
  },
  "output_types": {
    "text_output": {
      "type": "string",
      "label": "Texte transformé"
    },
    "bruteforce_solutions": {
      "type": "array",
      "label": "Solutions (bruteforce)"
    }
  }
} 